{
  "entities": {
    "Simulation": {
      "title": "Simulation",
      "description": "A record of a browser attack simulation run by a user.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The UID of the user who ran the simulation." },
        "name": { "type": "string", "description": "The name given to the simulation." },
        "attackType": { "type": "string", "enum": ["memory-extraction", "debugger-attachment", "dll-injection", "browser-hooking"], "description": "The type of attack simulated." },
        "timestamp": { "type": "number", "description": "The time the simulation was run." },
        "result": { "type": "string", "enum": ["success", "blocked"], "description": "Whether the attack succeeded or was blocked." },
        "riskLevel": { "type": "string", "enum": ["low", "medium", "high"], "description": "The calculated risk level of the simulation." },
        "steps": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "action": { "type": "string" },
              "status": { "type": "string", "enum": ["pending", "success", "failed"] },
              "timestamp": { "type": "number" },
              "riskFlag": { "type": "string", "enum": ["low", "medium", "high"] },
              "details": { "type": "string" }
            }
          }
        }
      },
      "required": ["userId", "name", "attackType", "timestamp", "result", "riskLevel", "steps"]
    }
  },
  "firestore": {
    "/simulations/{simulationId}": {
      "schema": "Simulation",
      "description": "Collection of all attack simulations."
    }
  }
}
